@page
@{
    ViewData["Title"] = "Ventes";
    Layout = "_DashboardLayout";
}

<div class="dashboard-header">
    <div class="dashboard-title">
        <h1>Historique des Ventes</h1>
        <p>Suivez les transactions et les tickets de caisse.</p>
    </div>
    <button class="btn-primary" onclick="loadSales()">
        <i class="fa-solid fa-rotate-right"></i>
        <span>Actualiser</span>
    </button>
</div>

<div class="glass-card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3 class="card-title">Transactions récentes</h3>
        <button class="btn-primary" style="padding: 0.5rem 1rem; font-size: 0.9rem;" onclick="openSaleModal()">
            <i class="fa-solid fa-cart-plus"></i> Nouvelle Vente
        </button>
    </div>
    <div class="table-responsive">
        <table class="data-table" id="salesTable">
            <thead>
                <tr>
                    <th>N° Vente</th>
                    <th>Date</th>
                    <th>Vendeur</th>
                    <th>Montant Total</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="6" class="text-center" style="color: var(--text-muted); padding: 2rem;">Chargement...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Sale -->
<div class="modal-overlay" id="saleModal">
    <div class="modal-content" style="max-width: 600px;">
        <div class="modal-header">
            <h3 id="saleModalTitle">Nouvelle Vente</h3>
            <button class="modal-close" onclick="closeSaleModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="padding: 1.5rem; max-height: 80vh; overflow-y: auto;">
            <form id="saleForm" onsubmit="saveSale(event)">
                <div class="form-group">
                    <label>Nom du Client (Optionnel)</label>
                    <input type="text" id="s_customer" placeholder="Ex: Jean Dupont">
                </div>
                
                <div class="form-group">
                    <label>Ajouter un Produit</label>
                    <div style="display: flex; gap: 0.5rem; align-items: flex-start;">
                        <div style="flex: 1;">
                            <select id="s_product_select">
                                <option disabled selected value="">Sélectionner un produit...</option>
                            </select>
                        </div>
                        <div style="width: 100px;">
                            <input type="number" id="s_product_qty" min="1" value="1" placeholder="Qté">
                        </div>
                        <button type="button" class="btn-primary" onclick="addToCart()">Ajouter</button>
                    </div>
                </div>

                <div class="form-group">
                    <label>Panier</label>
                    <table class="data-table" style="margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th>P.U.</th>
                                <th>Qté</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="cartTableBody">
                            <tr><td colspan="5" class="text-center" style="color: var(--text-muted); padding: 1rem;">Le panier est vide.</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="form-group" style="text-align: right;">
                    <label>Montant Total (FCFA)</label>
                    <input type="number" step="0.01" id="s_total" readonly value="0.00" style="text-align: right; font-weight: bold; background: var(--bg-card); color: var(--text-primary);">
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-secondary" onclick="closeSaleModal()">Annuler</button>
                    <button type="submit" class="btn-primary">Valider la vente</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Hidden Receipt Container for Printing -->
<div id="print-receipt-container" style="display: none;">
    <div class="receipt" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #000; max-width: 350px; margin: 0 auto; padding: 20px; background: #fff; line-height: 1.4;">
        
        <div style="text-align: center; margin-bottom: 20px;">
            <img id="r_shop_logo" src="" style="display:none; max-width: 100px; max-height: 100px; margin: 0 auto 10px; border-radius: 8px;">
            <h2 id="r_shop_name" style="margin: 0; font-size: 22px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">SMART STOCK</h2>
            <p style="margin: 5px 0 0; font-size: 14px; color: #555;">Ticket de Caisse</p>
        </div>
        
        <div style="border-top: 1px dashed #000; border-bottom: 1px dashed #000; padding: 10px 0; margin-bottom: 15px; font-size: 13px;">
            <table style="width: 100%; border-collapse: collapse;">
                <tr><td style="padding: 2px 0;"><strong>Date:</strong></td><td style="text-align: right;" id="r_date"></td></tr>
                <tr><td style="padding: 2px 0;"><strong>Vente N°:</strong></td><td style="text-align: right;" id="r_number"></td></tr>
                <tr><td style="padding: 2px 0;"><strong>Vendeur:</strong></td><td style="text-align: right;" id="r_seller"></td></tr>
                <tr id="r_customer_p" style="display: none;"><td style="padding: 2px 0;"><strong>Client:</strong></td><td style="text-align: right;" id="r_customer"></td></tr>
            </table>
        </div>
        
        <table style="width: 100%; font-size: 13px; border-collapse: collapse; margin-bottom: 15px;">
            <thead>
                <tr style="border-bottom: 1px solid #000;">
                    <th style="text-align: left; padding: 5px 0;">Article</th>
                    <th style="text-align: center; padding: 5px 0;">Qté</th>
                    <th style="text-align: right; padding: 5px 0;">Montant</th>
                </tr>
            </thead>
            <tbody id="r_items">
            </tbody>
        </table>
        
        <div style="border-top: 2px solid #000; padding-top: 10px; margin-bottom: 25px;">
            <table style="width: 100%; font-size: 16px; font-weight: bold;">
                <tr>
                    <td style="text-transform: uppercase;">Total</td>
                    <td style="text-align: right;"><span id="r_total"></span> FCFA</td>
                </tr>
            </table>
        </div>
        
        <div style="text-align: center; font-size: 12px; color: #444;">
            <p style="margin: 0 0 5px; font-weight: bold;">Merci de votre visite !</p>
            <p style="margin: 0; font-style: italic;">À très bientôt.</p>
        </div>
        
    </div>
</div>

<style>
@@media print {
    body * {
        visibility: hidden;
    }
    #print-receipt-container, #print-receipt-container * {
        visibility: visible;
    }
    #print-receipt-container {
        display: block !important;
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        margin: 0;
        padding: 0;
    }
}
</style>

@section Scripts {
    <script>
        let cartItems = [];
        let allProducts = [];

        async function openSaleModal() {
            document.getElementById('saleForm').reset();
            cartItems = [];
            updateCartUI();
            const select = document.getElementById('s_product_select');
            select.innerHTML = '<option disabled selected value="">Chargement...</option>';
            document.getElementById('saleModal').classList.add('show');
            
            try {
                const token = localStorage.getItem("jwtToken");
                const resp = await fetch('/api/products?pageNumber=1&pageSize=100', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(resp.ok) {
                    const result = await resp.json();
                    allProducts = result.items || result;
                    select.innerHTML = '<option disabled selected value="">Sélectionner un produit...</option>' + allProducts.map(p => 
                        `<option value="${p.id ?? p.Id}" data-price="${p.sellingPrice ?? p.SellingPrice}">[${p.sku || p.sKU || p.SKU || 'N/A'}] ${p.name || p.Name} - ${(p.sellingPrice ?? p.SellingPrice).toFixed(2)} FCFA (Stock: ${p.currentStock ?? p.CurrentStock})</option>`
                    ).join('');
                }
            } catch(e) {
                console.error("Impossible de charger les produits");
            }
        }

        function addToCart() {
            const select = document.getElementById('s_product_select');
            const qtyInput = document.getElementById('s_product_qty');
            
            const productId = parseInt(select.value);
            const qty = parseInt(qtyInput.value);
            
            if (!productId || isNaN(qty) || qty <= 0) return;
            
            const product = allProducts.find(p => (p.id ?? p.Id) === productId);
            if (!product) return;
            
            const existingItem = cartItems.find(i => i.productId === productId);
            if (existingItem) {
                existingItem.quantity += qty;
            } else {
                cartItems.push({
                    productId: productId,
                    name: product.name || product.Name,
                    price: product.sellingPrice ?? product.SellingPrice,
                    quantity: qty
                });
            }
            
            // Reset fields
            select.value = '';
            qtyInput.value = 1;
            
            updateCartUI();
        }

        function removeFromCart(productId) {
            cartItems = cartItems.filter(i => i.productId !== productId);
            updateCartUI();
        }

        function updateCartUI() {
            const tbody = document.getElementById('cartTableBody');
            const totalInput = document.getElementById('s_total');
            
            if (cartItems.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center" style="color: var(--text-muted); padding: 1rem;">Le panier est vide.</td></tr>';
                totalInput.value = "0.00";
                return;
            }
            
            let total = 0;
            tbody.innerHTML = cartItems.map(item => {
                const lineTotal = item.price * item.quantity;
                total += lineTotal;
                return `
                    <tr>
                        <td>${item.name}</td>
                        <td>${item.price.toFixed(2)} FCFA</td>
                        <td>${item.quantity}</td>
                        <td style="font-weight: bold;">${lineTotal.toFixed(2)} FCFA</td>
                        <td style="text-align: right;"><button type="button" class="btn-icon" style="color: var(--danger); font-size: 0.9rem;" onclick="removeFromCart(${item.productId})"><i class="fa-solid fa-xmark"></i></button></td>
                    </tr>
                `;
            }).join('');
            
            totalInput.value = total.toFixed(2);
        }

        function closeSaleModal() {
            document.getElementById('saleModal').classList.remove('show');
        }

        async function saveSale(e) {
            e.preventDefault();
            const token = localStorage.getItem("jwtToken");
            if (!token) return;

            const customerName = document.getElementById('s_customer').value;
            
            if (cartItems.length === 0) {
                showToast("Veuillez ajouter au moins un produit au panier", "warning");
                return;
            }

            const items = cartItems.map(i => ({
                productId: i.productId,
                quantity: i.quantity
            }));

            const requestBody = {
                customerName: customerName,
                notes: "",
                items: items
            };

            try {
                const resp = await fetch('/api/sales', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(requestBody)
                });

                if (!resp.ok) {
                    const errText = await resp.text();
                    let errMsg = errText;
                    try {
                        const errJson = JSON.parse(errText);
                        if (errJson.message) errMsg = errJson.message;
                    } catch (e) { }
                    throw new Error(errMsg);
                }
                
                const saleData = await resp.json();
                
                closeSaleModal();
                showToast('Vente enregistrée avec succès', 'success');
                loadSales();
                
                // Print receipt automatically
                printReceipt(saleData);
                
            } catch (error) {
                console.error(error);
                showToast("Erreur: " + error.message, "danger");
            }
        }
        
        async function printReceipt(sale) {
            try {
                const resp = await fetch('/api/settings');
                if (resp.ok) {
                    const data = await resp.json();
                    if (data.shopName) {
                        document.getElementById('r_shop_name').innerText = data.shopName;
                    }
                    if (data.logoBase64) {
                        const logoEl = document.getElementById('r_shop_logo');
                        if (logoEl) {
                            logoEl.src = data.logoBase64;
                            logoEl.style.display = 'inline-block';
                        }
                    }
                }
            } catch (e) { console.error('Settings load failed for receipt', e); }

            document.getElementById('r_date').innerText = new Date(sale.soldAt || sale.SoldAt).toLocaleString();
            document.getElementById('r_number').innerText = sale.saleNumber || sale.SaleNumber;
            document.getElementById('r_seller').innerText = sale.sellerName || sale.SellerName || 'N/A';
            
            const customer = sale.customerName || sale.CustomerName;
            if (customer) {
                document.getElementById('r_customer_p').style.display = 'block';
                document.getElementById('r_customer').innerText = customer;
            } else {
                document.getElementById('r_customer_p').style.display = 'none';
            }
            
            const items = sale.items || sale.Items || [];
            document.getElementById('r_items').innerHTML = items.map(i => `
                <tr>
                    <td style="padding: 6px 0; border-bottom: 1px solid #eee;">${i.productName || i.ProductName}</td>
                    <td style="text-align: center; padding: 6px 0; border-bottom: 1px solid #eee;">${i.quantity || i.Quantity}</td>
                    <td style="text-align: right; padding: 6px 0; border-bottom: 1px solid #eee;">${(i.totalPrice || i.TotalPrice).toFixed(2)}</td>
                </tr>
            `).join('');
            
            document.getElementById('r_total').innerText = (sale.totalAmount || sale.TotalAmount).toFixed(2);
            
            document.getElementById('print-receipt-container').style.display = 'block';
            window.print();
            document.getElementById('print-receipt-container').style.display = 'none';
        }

        function viewSale(saleNumber) {
            showToast('Détails de la vente ' + saleNumber, 'success');
        }

        async function reprintSale(id) {
            const token = localStorage.getItem("jwtToken");
            try {
                const resp = await fetch('/api/sales/' + id, {
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                if (!resp.ok) throw new Error('Erreur de chargement');
                const saleData = await resp.json();
                printReceipt(saleData);
            } catch (e) {
                console.error(e);
                showToast("Erreur lors de la récupération de la vente: " + e.message, "danger");
            }
        }

        function cancelSale(id) {
            showConfirmModal("Voulez-vous annuler cette vente ? Le stock sera restauré.", async () => {
                const token = localStorage.getItem("jwtToken");
                try {
                    const resp = await fetch('/api/sales/' + id + '/cancel', {
                        method: 'POST',
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    if (!resp.ok) {
                        const errText = await resp.text();
                        let errMsg = errText;
                        try {
                            const errJson = JSON.parse(errText);
                            if (errJson.message) errMsg = errJson.message;
                        } catch (e) { }
                        throw new Error(errMsg);
                    }
                    
                    showToast('Vente annulée avec succès', 'success');
                    loadSales();
                } catch(e) {
                    showToast("Erreur: " + e.message, "danger");
                }
            });
        }

        async function loadSales() {
            const token = localStorage.getItem("jwtToken");
            if (!token) {
                window.location.href = "/Login";
                return;
            }
            
            const tbody = document.querySelector('#salesTable tbody');
            tbody.innerHTML = '<tr><td colspan="6" class="text-center" style="color: var(--text-muted); padding: 2rem;">Chargement...</td></tr>';
            
            try {
                let fetchUrl = '/api/sales?pageNumber=1&pageSize=50';
                
                // Vérifier si l'utilisateur est un vendeur
                try {
                    const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));
                    const role = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
                    if (role === 'Vendeur') {
                        fetchUrl = '/api/sales/my-sales?pageNumber=1&pageSize=50';
                    }
                } catch(e) {}

                const resp = await fetch(fetchUrl, {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });
                if (resp.status === 401) {
                    window.location.href = "/Login";
                    return;
                }
                if (!resp.ok) throw new Error('Erreur API');
                
                const result = await resp.json();
                const sales = result.items || result;
                
                if (!sales || sales.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center" style="color: var(--text-muted); padding: 2rem;">Aucune vente trouvée.</td></tr>';
                    return;
                }
                
                tbody.innerHTML = sales.map(s => `
                    <tr>
                        <td style="font-weight: 500;">${s.saleNumber}</td>
                        <td>${new Date(s.soldAt).toLocaleString()}</td>
                        <td>${s.sellerName || '-'}</td>
                        <td style="font-weight: 600; color: var(--text-primary);">${s.totalAmount.toFixed(2)} FCFA</td>
                        <td>
                            <span class="badge" style="background: ${s.status === 'Completed' ? 'rgba(34, 197, 94, 0.2)' : 'rgba(239, 68, 68, 0.2)'}; color: ${s.status === 'Completed' ? 'var(--success)' : 'var(--danger)'};">
                                ${s.status}
                            </span>
                        </td>
                        <td style="white-space: nowrap;">
                            <button class="btn-icon" title="Voir le détail" style="color: var(--primary);" onclick="viewSale('${s.saleNumber}')"><i class="fa-solid fa-eye"></i></button>
                            ${s.status === 'Completed' ? `<button class="btn-icon" title="Annuler la vente" style="color: var(--danger); margin-left: 0.5rem;" onclick="cancelSale(${s.id})"><i class="fa-solid fa-ban"></i></button>` : ''}
                            <button class="btn-icon" title="Imprimer le reçu" style="color: var(--text-muted); margin-left: 0.5rem;" onclick="reprintSale(${s.id})"><i class="fa-solid fa-print"></i></button>
                        </td>
                    </tr>
                `).join('');
                
            } catch (e) {
                console.error(e);
                tbody.innerHTML = '<tr><td colspan="6" class="text-center" style="color: var(--danger); padding: 2rem;">Erreur lors du chargement des données.</td></tr>';
            }
        }
        
        document.addEventListener('DOMContentLoaded', loadSales);
    </script>
}
